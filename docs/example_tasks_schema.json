{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Software Project Hierarchy",
  "type": "object",
  "properties": {
    "project_name": { "type": "string" },
    "version": { "type": "string" },
    "epics": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "epic_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "stories": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "story_id": { "type": "string" },
                "user_role": { "type": "string" },
                "goal": { "type": "string" },
                "benefit": { "type": "string" },
                "subtasks": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string" },
                      "layer": { 
                        "type": "string",
                        "enum": ["Frontend", "Backend", "Database", "External", "DevOps"] 
                      },
                      "description": { "type": "string" },
                      "risk-score": { 
                        "type": "integer", 
                        "minimum": 1, 
                        "maximum": 10 
                      },
                      "human time estimate": { "type": "number" },
                      "agentic time estimate": { "type": "number" },
                      "is complete": { "type": "boolean" }
                    },
                    "required": [
                      "id", 
                      "layer", 
                      "description", 
                      "risk-score", 
                      "human time estimate", 
                      "agentic time estimate", 
                      "is complete"
                    ]
                  }
                }
              },
              "required": ["story_id", "goal", "subtasks"]
            }
          }
        },
        "required": ["epic_id", "title", "stories"]
      }
    }
  },
  "required": ["project_name", "epics"]
}